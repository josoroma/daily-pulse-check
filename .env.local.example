# Supabase
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54331
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Twelve Data (Stock prices)
TWELVE_DATA_API_KEY=your-twelve-data-key-here

# CoinGecko (Crypto prices) — free tier, no key required by default
# COINGECKO_API_KEY=your-coingecko-pro-key-here

# FRED (Macro indicators)
FRED_API_KEY=your-fred-key-here

# Alternative.me (Fear & Greed Index) — no key required

# OpenAI (Vercel AI SDK)
OPENAI_API_KEY=your-openai-key-here

# Telegram Bot (Notifications)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-telegram-chat-id-here
